#!/usr/bin/env bash
# ============================================================
#  install - termux-ubuntu-setup 全自动一键安装
#
#  使用方法（二选一）:
#    curl -fsSL https://raw.githubusercontent.com/Xynrin/termux-ubuntu-setup/main/install -o install && bash install
#    wget -qO- https://raw.githubusercontent.com/Xynrin/termux-ubuntu-setup/main/install -O install && bash install
#
#  本地交互管理: bash ~/termux-ubuntu-setup/tus
#
#  项目地址: https://github.com/Xynrin/termux-ubuntu-setup
#  许可证: MIT
# ============================================================

# 不使用 set -e 和 set -u，手动处理错误
# set -u 会导致引用未定义的环境变量（如 SVDIR）时报错终止
# set -e 会导致子进程失败时意外退出
set -o pipefail

# ---- 项目信息 ----
REPO_OWNER="${REPO_OWNER:-Xynrin}"
REPO_NAME="termux-ubuntu-setup"
REPO_URL="https://github.com/${REPO_OWNER}/${REPO_NAME}"
INSTALL_DIR="$HOME/${REPO_NAME}"

# ---- 颜色定义 ----
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ---- 日志函数 ----
log_info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }

# ---- 进度条 ----
show_progress() {
    local label="$1" total="$2" current="$3"
    local percent=$((current * 100 / total))
    local filled=$((current * 30 / total))
    local empty=$((30 - filled))
    printf "\r  ${CYAN}${label}${NC} ["
    printf "%${filled}s" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "] ${BOLD}%3d%%${NC}" "$percent"
    [ "$current" -ge "$total" ] && echo ""
}

# ---- Logo ----
show_logo() {
    clear
    echo -e "${CYAN}"
    cat <<'EOF'
    ╔══════════════════════════════════════════════════╗
    ║                                                  ║
    ║   _   _                  ____  _                 ║
    ║  | | | | __ _ _ __   ___/ ___|| |__   __ _ _ __  ║
    ║  | |_| |/ _` | '_ \ / _ \___ \| '_ \ / _` | '__| ║
    ║  |  _  | (_| | | | |  __/___) | | | | (_| | |    ║
    ║  |_| |_|\__,_|_| |_|\___|____/|_| |_|\__,_|_|    ║
    ║                                                  ║
    ║         Ubuntu Desktop on Android                ║
    ║         One-Click Setup Script                   ║
    ║                                                  ║
    ╚══════════════════════════════════════════════════╝
EOF
    echo -e "${NC}"
}

# ---- 分隔线 ----
show_separator() {
    echo -e "  ${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ---- 完成横幅 ----
show_complete() {
    echo ""
    echo -e "${GREEN}"
    cat <<'EOF'
    ╔══════════════════════════════════════════════════╗
    ║                                                  ║
    ║          ✨  安装完成！  ✨                       ║
    ║                                                  ║
    ╚══════════════════════════════════════════════════╝
EOF
    echo -e "${NC}"
}

# ---- 环境检测 ----
check_environment() {
    if [ ! -d "/data/data/com.termux" ] && [ -z "${TERMUX_VERSION:-}" ]; then
        echo -e "${RED}[ERROR] 此脚本必须在 Termux 环境中运行！${NC}"
        echo ""
        echo -e "  请从以下地址下载安装 Termux："
        echo -e "    ${CYAN}https://github.com/termux/termux-app/releases${NC}"
        echo -e "    ${CYAN}https://f-droid.org/packages/com.termux/${NC}"
        exit 1
    fi

    log_info "检查网络连接..."
    if ping -c 1 -W 5 google.com &>/dev/null || ping -c 1 -W 5 baidu.com &>/dev/null; then
        log_ok "网络连接正常"
    else
        log_error "网络连接失败，请检查网络设置"
        exit 1
    fi
}

# ---- 下载项目 ----
download_project() {
    echo ""
    log_info "正在下载项目文件..."

    if [ -d "$INSTALL_DIR" ]; then
        log_warn "检测到项目目录已存在，跳过下载"
        return 0
    fi

    # 优先使用 git clone
    if command -v git &>/dev/null; then
        if git clone --depth 1 "https://github.com/${REPO_OWNER}/${REPO_NAME}.git" "$INSTALL_DIR" 2>/dev/null; then
            log_ok "项目下载完成"
            return 0
        fi
    fi

    # git 失败，尝试 wget/curl 下载 zip
    log_warn "Git 克隆失败，尝试下载压缩包..."
    local zip_url="https://github.com/${REPO_OWNER}/${REPO_NAME}/archive/refs/heads/main.zip"
    local tmp_zip="/tmp/${REPO_NAME}.zip"

    if command -v wget &>/dev/null; then
        wget -q "$zip_url" -O "$tmp_zip" 2>/dev/null
    elif command -v curl &>/dev/null; then
        curl -fsSL "$zip_url" -o "$tmp_zip" 2>/dev/null
    fi

    if [ -f "$tmp_zip" ]; then
        command -v unzip &>/dev/null || pkg install -y unzip &>/dev/null
        unzip -q "$tmp_zip" -d /tmp/ 2>/dev/null
        mv "/tmp/${REPO_NAME}-main" "$INSTALL_DIR" 2>/dev/null
        rm -f "$tmp_zip"
        log_ok "项目下载完成"
        return 0
    fi

    log_error "项目下载失败"
    log_info "请手动执行: git clone ${REPO_URL}"
    exit 1
}

# ---- 加载模块 ----
load_modules() {
    local lib_file="$INSTALL_DIR/lib/common.sh"
    local modules_dir="$INSTALL_DIR/modules"

    if [ ! -f "$lib_file" ]; then
        log_error "找不到公共库: $lib_file"
        exit 1
    fi
    source "$lib_file"

    for module in "$modules_dir"/*.sh; do
        [ -f "$module" ] && source "$module"
    done
}

# ---- 全自动安装 ----
install_all() {
    echo ""
    show_separator
    echo -e "  ${BOLD}${GREEN}🚀 开始全自动安装${NC}"
    show_separator
    echo ""

    local steps=(
        "setup_termux:配置 Termux 基础环境"
        "setup_ubuntu:安装 Ubuntu 系统"
        "setup_desktop:安装桌面环境"
        "setup_software:安装应用软件"
        "setup_extras:安装字体和辅助功能"
    )

    local total=${#steps[@]}
    local current=0
    local failed=0

    for step in "${steps[@]}"; do
        ((current++))
        local func="${step%%:*}"
        local desc="${step##*:}"

        echo ""
        show_progress "安装进度" "$total" "$current"

        if ! $func; then
            log_error "${desc} 失败！"
            ((failed++))
        fi
    done

    echo ""
    show_progress "安装进度" "$total" "$total"

    if [ "$failed" -eq 0 ]; then
        show_complete
    else
        echo ""
        log_warn "${failed} 个步骤失败，可使用 tus 命令重新执行"
    fi
}

# ---- 显示使用说明 ----
show_usage_info() {
    echo ""
    show_separator
    echo -e "  ${BOLD}${CYAN}📖 使用说明${NC}"
    show_separator
    echo ""
    echo -e "  ${WHITE}启动桌面:${NC}"
    echo -e "    ${CYAN}~/start-desktop.sh${NC}"
    echo ""
    echo -e "  ${WHITE}进入 Ubuntu:${NC}"
    echo -e "    ${CYAN}proot-distro login ubuntu${NC}"
    echo ""
    echo -e "  ${WHITE}启动浏览器:${NC}"
    echo -e "    ${CYAN}proot-distro login --shared-tmp ubuntu -- bash -c 'export DISPLAY=:0; firefox-esr'${NC}"
    echo ""
    echo -e "  ${WHITE}启动 VS Code:${NC}"
    echo -e "    ${CYAN}proot-distro login --shared-tmp ubuntu -- bash -c 'export DISPLAY=:0; code --no-sandbox'${NC}"
    echo ""
    echo -e "  ${WHITE}本地管理菜单:${NC}"
    echo -e "    ${CYAN}bash ~/termux-ubuntu-setup/tus${NC}"
    echo ""
    echo -e "  ${DIM}默认用户名: user  默认密码: 1234${NC}"
    echo -e "  ${DIM}请登录后使用 passwd 命令修改密码${NC}"
    echo ""
    echo -e "  ${DIM}请确保已安装 Termux:X11 App${NC}"
    echo -e "  ${DIM}下载: https://github.com/termux/termux-x11/releases${NC}"
    echo ""
}

# ============================================================
#  主流程
# ============================================================

main() {
    show_logo
    echo ""
    log_info "欢迎使用 Termux Ubuntu 一键配置工具！"
    echo ""

    check_environment
    download_project

    log_info "加载模块..."
    load_modules
    log_ok "模块加载完成"

    # 创建 tus 快捷命令
    local tus_bin="$PREFIX/bin/tus"
    if [ -n "${PREFIX:-}" ] && [ ! -f "$tus_bin" ]; then
        ln -sf "$INSTALL_DIR/tus" "$tus_bin" 2>/dev/null
        chmod +x "$tus_bin" 2>/dev/null
        log_ok "已创建快捷命令: tus"
    fi

    # 全自动安装
    install_all

    # 显示使用说明
    show_usage_info
}

main "$@"
